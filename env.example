# Your domain (must be a subdomain, e.g. app.example.dk)
DOMAIN=sub.example.dk

# Published container image used by docker compose
CERTBOT_IMAGE=ghcr.io/enoch85/certbot-dns-scannet:latest

# Email for Let's Encrypt notifications
ACME_EMAIL=you@example.dk

# ScanNet API credentials
# Create at: controlpanel.scannet.dk → Min konto → API applikationer → toggle DNS
SCANNET_CLIENT_ID=
SCANNET_CLIENT_SECRET=
